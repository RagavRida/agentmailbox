{
  "name": "agentmail-mcp",
  "version": "0.1.0",
  "description": "MCP server adapter for AgentMail",
  "bin": {
    "agentmail-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "type": "commonjs",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:parent": "cd .. && npm install --no-audit --no-fund && npm run build",
    "postinstall": "node -e \"const fs=require('fs');if(!fs.existsSync('../dist/agentmail.js')){require('child_process').execSync('npm run build:parent',{stdio:'inherit'});}\"",
    "build": "tsc && node scripts/finalize.js",
    "start": "ts-node src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentmail",
    "mcp",
    "model-context-protocol",
    "agents",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RagavRida/agentmail.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/RagavRida/agentmail/tree/main/mcp",
  "bugs": {
    "url": "https://github.com/RagavRida/agentmail/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
