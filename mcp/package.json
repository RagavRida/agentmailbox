{
  "name": "agentsmcp-adapter",
  "version": "0.2.0",
  "description": "DEPRECATED — use 'npx agentsmcp' instead. Thin shim that delegates to the main agentsmcp package.",
  "bin": {
    "agentsmcp-adapter": "dist/index.js"
  },
  "main": "dist/index.js",
  "type": "commonjs",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/finalize.js",
    "start": "ts-node src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentsmcp",
    "agentmailbox",
    "mcp",
    "model-context-protocol",
    "agents",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RagavRida/agentsmcp.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/RagavRida/agentsmcp/tree/main/mcp",
  "bugs": {
    "url": "https://github.com/RagavRida/agentsmcp/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "deprecated": "Use 'npx agentsmcp' directly. This package is a thin shim.",
  "dependencies": {
    "agentsmcp": ">=0.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
