{
  "name": "agentsmcp",
  "version": "0.4.0",
  "description": "Context-sync protocol for AI agents. Every agent has a mailbox.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentsmcp": "dist/mcp/index.js",
    "agentsmcp-server": "dist/server.js",
    "agentmailbox-server": "dist/server.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc && node scripts/finalize-mcp.js",
    "start": "ts-node src/server.ts",
    "example": "ts-node examples/basic.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:e2e": "npm run build && node scripts/smoke-e2e.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "agents",
    "ai",
    "context",
    "protocol",
    "mailbox",
    "llm",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RagavRida/agentsmcp.git"
  },
  "homepage": "https://agentmailbox.vercel.app",
  "bugs": {
    "url": "https://github.com/RagavRida/agentsmcp/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.6",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.27.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "openai": "^4.50.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
